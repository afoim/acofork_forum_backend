JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key
TURNSTILE_SECRET_KEY=your-cloudflare-turnstile-secret-key

# AWS S3 Configuration
# AWS_ENDPOINT: Public endpoint for frontend access (e.g., https://your-cdn.com)
# AWS_ENDPOINT_BACKEND: Backend API endpoint for direct S3 operations (e.g., https://s3.amazonaws.com)
# If AWS_ENDPOINT_BACKEND is not set, AWS_ENDPOINT will be used for both
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=your-aws-region
AWS_ENDPOINT=https://your-public-endpoint.com
AWS_ENDPOINT_BACKEND=https://your-backend-api-endpoint.com
AWS_BUCKET=your-bucket-name
AWS_PATH_PREFIX=optional-path-prefix
